# --- Supabase (base Postgres, OBLIGATOIRE) -------------------------------
# L'application stocke les articles dans une table Postgres hébergée par
# Supabase. Free tier : 500 MB / 50 000 utilisateurs actifs / 2 Go bandwidth.
#
# Mise en place (5 minutes) :
#   1. https://supabase.com/ -> Sign up (GitHub recommandé)
#   2. New Project -> choisir un nom + un mot de passe DB + une région proche
#   3. Project Settings -> API
#        - copier 'Project URL'           -> SUPABASE_URL
#        - copier la clé 'service_role'   -> SUPABASE_SERVICE_ROLE_KEY
#          (c'est la clé secrète server-side, ne JAMAIS l'exposer au client)
#   4. SQL Editor -> New query -> coller le contenu de supabase/schema.sql
#      -> RUN. Crée la table 'articles' avec ses index.
#
# Sur Vercel : ajouter ces 2 variables dans Project Settings -> Environment
# Variables (Production + Preview).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Gemini (obligatoire pour la description, prix estimés, catégorie) ---
# Obtenir une clé (gratuite) : https://aistudio.google.com/app/apikey
#
# POOL DE CLÉS AVEC ROTATION AUTOMATIQUE
# --------------------------------------
# Le quota gratuit Gemini est limité (~15 req/min/clé sur gemini-2.5-flash).
# Pour contourner cette limite, l'app supporte un POOL de clés qu'elle utilise
# en round-robin et fait basculer automatiquement quand l'une est :
#   - rate-limited (429)            -> mise en cooldown 1 minute
#   - invalide/désactivée (403)     -> mise en cooldown 1 heure
# Le rapport de statut s'affiche au démarrage côté serveur.
#
# Configurez de 1 à 20 clés. L'app détecte automatiquement celles définies.
# (Les clés vides sont ignorées, l'ordre des indices n'a pas d'importance.)
GEMINI_API_KEY=
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
GEMINI_API_KEY_6=
GEMINI_API_KEY_7=
GEMINI_API_KEY_8=
GEMINI_API_KEY_9=
GEMINI_API_KEY_10=
GEMINI_MODEL=gemini-2.5-flash

# --- Google Cloud Vision (optionnel, en complément du LLM vision) ---
# Active l'enrichissement automatique :
#   - Logo detection -> marque (haute confiance)
#   - OCR (text detection) -> code-barres (EAN/UPC), dimensions, prix d'étiquette
#   - Label/Object detection -> catégorie de fallback
# Création :
#   1. https://console.cloud.google.com/ -> nouveau projet
#   2. Activer la facturation (gratuit jusqu'à 1000 req/mois/feature)
#   3. APIs & Services -> Library -> "Cloud Vision API" -> Enable
#   4. APIs & Services -> Credentials -> Create credentials -> API key
#   5. (recommandé) Restreindre la clé à l'API "Cloud Vision API"
GOOGLE_VISION_API_KEY=

# --- Groq (FALLBACK #1 quand toutes les clés Gemini sont épuisées) -------------
# Llama 3.2 / Llama 4 Vision via API compatible OpenAI.
# Free tier : ~14 400 req/jour (10x plus que Gemini), sans carte bancaire.
# Inscription : https://console.groq.com/keys -> "Create API Key"
#
# Modèles vision recommandés (mettre à jour si Groq retire l'un d'eux) :
#   - llama-3.2-11b-vision-preview   (par défaut, free tier généreux)
#   - llama-3.2-90b-vision-preview   (qualité supérieure, plus lent)
#   - meta-llama/llama-4-maverick    (le plus récent, limité à ~500 req/jour)
GROQ_API_KEY=
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_MODEL=llama-3.2-11b-vision-preview
# Modèle texte pour le fallback codes-barres (text-only, plus connaissant)
# Recommandés : llama-3.3-70b-versatile (par défaut), llama-3.1-70b-versatile
GROQ_TEXT_MODEL=llama-3.3-70b-versatile

# --- Mistral AI (FALLBACK #2 quand Gemini et Groq sont tous deux épuisés) ------
# Pixtral 12B / Pixtral Large via API compatible OpenAI.
# Free tier : 1 milliard tokens/mois, mais limité à 2 req/min (donc à utiliser
# en dernier recours uniquement, sinon ça ralentit l'application).
# Inscription : https://console.mistral.ai/api-keys -> "Create new key"
#
# Modèles vision recommandés :
#   - pixtral-12b-latest   (par défaut)
#   - pixtral-large-latest (qualité supérieure, mêmes limites)
MISTRAL_API_KEY=
MISTRAL_API_KEY_1=
MISTRAL_API_KEY_2=
MISTRAL_MODEL=pixtral-12b-latest
# Modèle texte pour le fallback codes-barres (text-only, économe en tokens)
# Recommandés : mistral-small-latest (par défaut), mistral-large-latest
MISTRAL_TEXT_MODEL=mistral-small-latest

# --- Authentification — page de code d'accès (OBLIGATOIRE) --------------------
# L'application est protégée par un code à 6 chiffres saisi sur /code. Une fois
# le code validé, un cookie de session HttpOnly+SameSite=Lax est posé pour
# 30 minutes ; au-delà, l'utilisateur est automatiquement renvoyé sur /code.
#
# APP_ACCESS_CODE : exactement 6 chiffres (0-9). Par défaut "110706" si la
# variable est absente. Pour la production, choisissez un code non trivial.
APP_ACCESS_CODE=110706
#
#
# APP_AUTH_SECRET : secret HMAC utilisé pour signer le cookie de session.
# Indispensable en production : sans secret stable, toutes les sessions
# seraient invalidées à chaque redémarrage du serveur.
# Générer un secret aléatoire (64 caractères hex) :
#   PowerShell : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   Bash       : openssl rand -hex 32
# Ne jamais committer la valeur réelle — uniquement dans .env (gitignored).
APP_AUTH_SECRET=

# Durée de session en heures (défaut : 24).
APP_SESSION_TTL_HOURS=24

# --- Cloudinary (Optionnel, recommandé pour économiser le quota Supabase) ----
# Utilisé pour stocker les photos d'article à l'extérieur de la base de données.
# 1. Créez un compte gratuit sur https://cloudinary.com/
# 2. Copiez votre "Cloud Name" -> PUBLIC_CLOUDINARY_CLOUD_NAME
# 3. Allez dans Settings -> Upload -> "Add upload preset"
#    - Signing Mode: Unsigned
#    - Nommez-le (ex: "marchedemo_unsigned") -> PUBLIC_CLOUDINARY_UPLOAD_PRESET
#
PUBLIC_CLOUDINARY_CLOUD_NAME=
PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# --- Branding (utilisé dans le titre, le footer et les exports CSV/PDF) ------
# Ces deux variables apparaissent uniquement comme métadonnées (titres
# d'export, copyright). Aucune valeur sensible.
PUBLIC_BRAND_NAME=Marché de Mo'
PUBLIC_BRAND_TAGLINE=Inventaire intelligent



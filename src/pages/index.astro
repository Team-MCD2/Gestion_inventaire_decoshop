---
import Layout from '../layouts/Layout.astro';
---
<Layout>
  <!-- HEADER -->
  <header class="sticky top-0 z-40 bg-white/85 backdrop-blur-md border-b border-slate-200">
    <div class="max-w-7xl mx-auto flex items-center justify-between gap-3 p-3 md:p-4">
      <div class="flex items-center gap-3 min-w-0">
        <div class="relative h-10 w-10 md:h-12 md:w-12 shrink-0 rounded-full overflow-hidden ring-2 ring-white shadow-md">
          <img src="/favicon.svg" alt="DECO SHOP" class="h-full w-full" />
        </div>
        <div class="min-w-0">
          <h1 class="text-base md:text-xl font-extrabold text-slate-900 tracking-tight truncate">
            DECO SHOP — Inventaire intelligent
          </h1>
          <p class="hidden md:block text-xs text-slate-500">Caméra · IA · Code-barres · Export CSV</p>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <span class="hidden sm:inline-flex items-center gap-1.5 rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">
          <span class="h-2 w-2 rounded-full bg-emerald-500"></span>
          <span id="inventory-count">0</span> articles
        </span>
        <button id="btn-settings" type="button"
          class="inline-flex items-center gap-1.5 rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.7 1.7 0 0 0 .3 1.8l.1.1a2 2 0 1 1-2.8 2.8l-.1-.1a1.7 1.7 0 0 0-1.8-.3 1.7 1.7 0 0 0-1 1.5V21a2 2 0 1 1-4 0v-.1a1.7 1.7 0 0 0-1.1-1.5 1.7 1.7 0 0 0-1.8.3l-.1.1a2 2 0 1 1-2.8-2.8l.1-.1a1.7 1.7 0 0 0 .3-1.8 1.7 1.7 0 0 0-1.5-1H3a2 2 0 1 1 0-4h.1a1.7 1.7 0 0 0 1.5-1.1 1.7 1.7 0 0 0-.3-1.8l-.1-.1a2 2 0 1 1 2.8-2.8l.1.1a1.7 1.7 0 0 0 1.8.3H9a1.7 1.7 0 0 0 1-1.5V3a2 2 0 1 1 4 0v.1a1.7 1.7 0 0 0 1 1.5 1.7 1.7 0 0 0 1.8-.3l.1-.1a2 2 0 1 1 2.8 2.8l-.1.1a1.7 1.7 0 0 0-.3 1.8V9a1.7 1.7 0 0 0 1.5 1H21a2 2 0 1 1 0 4h-.1a1.7 1.7 0 0 0-1.5 1z"/></svg>
          <span class="hidden sm:inline">Paramètres</span>
        </button>
      </div>
    </div>
  </header>

  <main class="max-w-7xl mx-auto p-4 md:p-6 lg:p-8 space-y-6">

    <!-- ACTION TILES -->
    <section class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-4">
      <button id="btn-open-photo" type="button"
        class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-indigo-600 via-indigo-600 to-blue-700 text-white p-5 md:p-6 text-left shadow-lg ring-1 ring-indigo-500/30 hover:shadow-xl hover:-translate-y-0.5 transition">
        <div class="flex items-start gap-4">
          <div class="h-12 w-12 rounded-xl bg-white/15 backdrop-blur flex items-center justify-center ring-1 ring-white/25">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
          </div>
          <div class="flex-1 min-w-0">
            <div class="text-lg md:text-xl font-bold">Filmer l'article</div>
            <div class="text-sm text-white/80 mt-0.5">Analyse IA de la photo pour pré-remplir les champs</div>
          </div>
        </div>
      </button>

      <button id="btn-open-barcode" type="button"
        class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-amber-500 via-amber-500 to-orange-500 text-white p-5 md:p-6 text-left shadow-lg ring-1 ring-amber-500/30 hover:shadow-xl hover:-translate-y-0.5 transition">
        <div class="flex items-start gap-4">
          <div class="h-12 w-12 rounded-xl bg-white/15 backdrop-blur flex items-center justify-center ring-1 ring-white/25">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 5v14"/><path d="M7 5v14"/><path d="M11 5v14"/><path d="M15 5v14"/><path d="M19 5v14"/></svg>
          </div>
          <div class="flex-1 min-w-0">
            <div class="text-lg md:text-xl font-bold">Scanner le code-barres</div>
            <div class="text-sm text-white/90 mt-0.5">EAN / UPC / QR : identification automatique</div>
          </div>
        </div>
      </button>
    </section>

    <!-- FORM -->
    <section class="bg-white rounded-2xl shadow-sm ring-1 ring-slate-200 overflow-hidden">
      <div class="flex items-center justify-between gap-3 px-5 py-4 border-b border-slate-200 bg-slate-50/60">
        <div class="flex items-center gap-2 min-w-0">
          <div class="h-2 w-2 rounded-full bg-indigo-500"></div>
          <h2 id="form-title" class="text-base font-semibold text-slate-900 truncate">Nouvel article</h2>
        </div>
        <button id="btn-clear" type="button" class="text-sm text-slate-600 hover:text-slate-900 font-medium">Effacer</button>
      </div>

      <form id="article-form" class="p-4 md:p-6">
        <div class="grid grid-cols-1 lg:grid-cols-[220px_1fr] gap-6">
          <div class="flex lg:block">
            <div class="w-full max-w-[220px]">
              <label class="block text-xs font-semibold text-slate-600 mb-2">Photo</label>
              <div class="relative aspect-square w-full rounded-xl ring-1 ring-slate-200 bg-slate-50 overflow-hidden cursor-pointer group">
                <div id="photo-placeholder" class="absolute inset-0 flex flex-col items-center justify-center text-slate-400 p-4 text-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 mb-2 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                  <div class="text-xs font-medium">Aucune photo</div>
                  <div class="text-[11px] text-slate-400 mt-1">Utilisez « Filmer l'article »</div>
                </div>
                <img id="photo-preview" class="hidden absolute inset-0 w-full h-full object-cover transition group-hover:scale-[1.02]" data-src="" alt="Photo de l'article" />
              </div>
            </div>
          </div>

          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4">
            <div>
              <label for="num_article" class="block text-xs font-semibold text-slate-600 mb-1">Num article</label>
              <input id="num_article" name="num_article" type="text" required
                class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-mono shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-none" />
            </div>
            <div>
              <label for="categorie" class="block text-xs font-semibold text-slate-600 mb-1">Catégorie</label>
              <input id="categorie" name="categorie" type="text" list="list-categories" autocomplete="off"
                class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-none" />
              <datalist id="list-categories">
                <option value="Mobilier"></option>
                <option value="Luminaire"></option>
                <option value="Textile"></option>
                <option value="Décoration murale"></option>
                <option value="Vaisselle"></option>
                <option value="Électroménager"></option>
                <option value="Jardin"></option>
                <option value="Rangement"></option>
                <option value="Jouet"></option>
                <option value="Électronique"></option>
                <option value="Autre"></option>
              </datalist>
            </div>
            <div>
              <label for="reference" class="block text-xs font-semibold text-slate-600 mb-1">Référence</label>
              <input id="reference" name="reference" type="text" autocomplete="off" placeholder="EAN / SKU"
                class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-mono shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-none" />
            </div>
            <div>
              <label for="couleur" class="block text-xs font-semibold text-slate-600 mb-1">Couleur</label>
              <input id="couleur" name="couleur" type="text" autocomplete="off"
                class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-none" />
            </div>
            <div>
              <label for="marque" class="block text-xs font-semibold text-slate-600 mb-1">Marque</label>
              <input id="marque" name="marque" type="text" autocomplete="off"
                class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-none" />
            </div>
            <div>
              <label for="modele" class="block text-xs font-semibold text-slate-600 mb-1">Modèle</label>
              <input id="modele" name="modele" type="text" autocomplete="off"
                class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-none" />
            </div>
            <div class="col-span-2">
              <label for="dimension" class="block text-xs font-semibold text-slate-600 mb-1">Dimensions</label>
              <input id="dimension" name="dimension" type="text" autocomplete="off" placeholder="ex: L120 x l60 x H75 cm"
                class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-none" />
            </div>
            <div class="col-span-2 md:col-span-3 lg:col-span-4">
              <label for="description" class="block text-xs font-semibold text-slate-600 mb-1">Description</label>
              <textarea id="description" name="description" rows="2"
                class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-none resize-none"></textarea>
            </div>

            <div class="col-span-2 md:col-span-3 lg:col-span-4 grid grid-cols-3 gap-3 md:gap-4 p-3 md:p-4 rounded-xl bg-slate-50 ring-1 ring-slate-200">
              <div>
                <label for="prix_achat" class="block text-xs font-semibold text-slate-600 mb-1">Prix d'achat (€)</label>
                <input id="prix_achat" name="prix_achat" type="number" min="0" step="0.01" inputmode="decimal"
                  class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm tabular-nums shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-none" />
              </div>
              <div>
                <label for="prix_vente" class="block text-xs font-semibold text-slate-600 mb-1">Prix de vente (€)</label>
                <input id="prix_vente" name="prix_vente" type="number" min="0" step="0.01" inputmode="decimal"
                  class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm tabular-nums shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-none" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-600 mb-1">Marge (auto)</label>
                <div id="marge-display" class="w-full rounded-lg border border-dashed border-slate-300 bg-white px-3 py-2 text-sm font-semibold tabular-nums text-slate-500">0,00 €</div>
              </div>
            </div>

            <div class="col-span-2 md:col-span-3 lg:col-span-4 grid grid-cols-3 gap-3 md:gap-4 p-3 md:p-4 rounded-xl bg-slate-50 ring-1 ring-slate-200">
              <div>
                <label for="quantite_initiale" class="block text-xs font-semibold text-slate-600 mb-1">Quantité initiale</label>
                <input id="quantite_initiale" name="quantite_initiale" type="number" min="0" step="1" value="1" inputmode="numeric"
                  class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm tabular-nums shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-none" />
              </div>
              <div>
                <label for="quantite_actuelle" class="block text-xs font-semibold text-slate-600 mb-1">Quantité actuelle</label>
                <input id="quantite_actuelle" name="quantite_actuelle" type="number" min="0" step="1" value="1" inputmode="numeric"
                  class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm tabular-nums shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-none" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-600 mb-1">Statut (auto)</label>
                <div id="statut-preview" class="flex items-center h-[38px] px-1"></div>
              </div>
            </div>
          </div>
        </div>

        <div class="mt-6 flex flex-col-reverse sm:flex-row sm:items-center sm:justify-end gap-2 pt-4 border-t border-slate-100">
          <button type="submit" id="btn-submit"
            class="inline-flex justify-center items-center gap-2 rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
            Ajouter à l'inventaire
          </button>
        </div>
      </form>
    </section>

    <!-- INVENTORY TABLE -->
    <section class="bg-white rounded-2xl shadow-sm ring-1 ring-slate-200 overflow-hidden">
      <div class="flex flex-wrap items-center justify-between gap-3 px-5 py-4 border-b border-slate-200 bg-slate-50/60">
        <div class="flex items-center gap-2">
          <div class="h-2 w-2 rounded-full bg-emerald-500"></div>
          <h2 class="text-base font-semibold text-slate-900">Inventaire</h2>
        </div>
        <div class="flex flex-wrap gap-2">
          <button id="btn-export-csv" type="button"
            class="inline-flex items-center gap-1.5 rounded-lg bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
            CSV
          </button>
          <button id="btn-export-pdf" type="button"
            class="inline-flex items-center gap-1.5 rounded-lg bg-red-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-700">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M10 12h1v4"/><path d="M9 12h3"/><path d="M16 12h-2v4h2"/><path d="M14 14h1.5"/></svg>
            PDF
          </button>
          <button id="btn-clear-all" type="button"
            class="inline-flex items-center gap-1.5 rounded-lg border border-red-200 bg-white px-3 py-2 text-sm font-medium text-red-600 hover:bg-red-50">
            Vider tout
          </button>
        </div>
      </div>

      <div class="overflow-x-auto">
        <table class="min-w-full text-sm">
          <thead class="bg-slate-50 text-[11px] uppercase tracking-wider text-slate-500 border-b border-slate-200">
            <tr>
              <th class="px-3 py-2 text-left font-semibold">Num article</th>
              <th class="px-3 py-2 text-left font-semibold">Photo</th>
              <th class="px-3 py-2 text-left font-semibold">Catégorie</th>
              <th class="px-3 py-2 text-left font-semibold">Marque</th>
              <th class="px-3 py-2 text-left font-semibold">Modèle</th>
              <th class="px-3 py-2 text-left font-semibold">Description</th>
              <th class="px-3 py-2 text-right font-semibold">P. achat</th>
              <th class="px-3 py-2 text-right font-semibold">P. vente</th>
              <th class="px-3 py-2 text-right font-semibold">Marge</th>
              <th class="px-3 py-2 text-left font-semibold">Référence</th>
              <th class="px-3 py-2 text-left font-semibold">Couleur</th>
              <th class="px-3 py-2 text-left font-semibold">Dimension</th>
              <th class="px-3 py-2 text-right font-semibold">Qté init.</th>
              <th class="px-3 py-2 text-right font-semibold">Qté act.</th>
              <th class="px-3 py-2 text-left font-semibold">Statut</th>
              <th class="px-3 py-2 text-right font-semibold">Actions</th>
            </tr>
          </thead>
          <tbody id="inventory-tbody" class="divide-y divide-slate-100 bg-white"></tbody>
        </table>
        <div id="inventory-loading" class="hidden py-16 px-6 text-center text-slate-400">
          <div class="h-10 w-10 mx-auto mb-3 rounded-full border-4 border-slate-200 border-t-indigo-500 animate-spin"></div>
          <p class="text-sm font-medium">Chargement de l'inventaire…</p>
        </div>
        <div id="inventory-empty" class="hidden py-16 px-6 text-center text-slate-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto mb-3 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7h-3V4a1 1 0 0 0-1-1H8a1 1 0 0 0-1 1v3H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1V8a1 1 0 0 0-1-1z"/><path d="M9 7V5h6v2"/></svg>
          <p class="text-sm font-medium">Votre inventaire est vide</p>
          <p class="text-xs text-slate-400 mt-1">Filmez un article ou scannez un code-barres pour commencer</p>
        </div>
      </div>
    </section>

    <footer class="pt-4 text-center text-xs text-slate-400">
      DECO SHOP · Inventaire intelligent · Stockage SQLite3 · Export CSV / PDF
    </footer>
  </main>

  <!-- SCANNER MODAL -->
  <div id="scanner-modal" class="hidden fixed inset-0 z-50 items-center justify-center p-0 md:p-4">
    <div id="scanner-backdrop" class="absolute inset-0 bg-black/85 backdrop-blur-sm"></div>
    <div class="relative w-full h-full md:h-auto md:max-h-[92vh] md:max-w-3xl md:rounded-2xl bg-slate-900 overflow-hidden shadow-2xl flex flex-col">
      <div class="flex items-center justify-between gap-3 px-4 md:px-5 py-3 bg-slate-950/60 text-white border-b border-white/10">
        <div class="flex items-center gap-2">
          <div class="h-2 w-2 rounded-full bg-red-500 pulse-ring"></div>
          <span id="scanner-mode-label" class="font-semibold text-sm">Capture photo</span>
        </div>
        <button id="btn-close-scanner" type="button"
          class="inline-flex h-9 w-9 items-center justify-center rounded-lg hover:bg-white/10">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>

      <div class="relative flex-1 min-h-0 bg-black">
        <video id="scanner-video" class="scanner-video" autoplay playsinline muted></video>

        <!-- Barcode frame overlay -->
        <div id="barcode-frame" class="hidden pointer-events-none absolute inset-0 flex items-center justify-center">
          <div class="relative w-[85%] max-w-md aspect-[4/1.2] rounded-xl border-2 border-amber-400/80 shadow-[0_0_0_9999px_rgba(0,0,0,0.35)] overflow-hidden">
            <div class="absolute inset-x-0 top-0 h-0.5 bg-amber-400 scan-line shadow-[0_0_12px_rgba(251,191,36,0.8)]"></div>
            <div class="absolute -top-1 -left-1 h-5 w-5 border-t-4 border-l-4 border-amber-400 rounded-tl-lg"></div>
            <div class="absolute -top-1 -right-1 h-5 w-5 border-t-4 border-r-4 border-amber-400 rounded-tr-lg"></div>
            <div class="absolute -bottom-1 -left-1 h-5 w-5 border-b-4 border-l-4 border-amber-400 rounded-bl-lg"></div>
            <div class="absolute -bottom-1 -right-1 h-5 w-5 border-b-4 border-r-4 border-amber-400 rounded-br-lg"></div>
          </div>
        </div>

        <!-- Loading overlay -->
        <div id="scanner-loading" class="hidden absolute inset-0 bg-black/70 backdrop-blur-sm flex flex-col items-center justify-center text-white gap-3">
          <div class="h-14 w-14 rounded-full border-4 border-white/20 border-t-white animate-spin"></div>
          <div id="scanner-loading-label" class="text-sm font-medium">Analyse IA en cours…</div>
        </div>
      </div>

      <div class="px-4 md:px-5 py-3 md:py-4 bg-slate-950/70 text-white border-t border-white/10 flex flex-col sm:flex-row items-center gap-3">
        <div id="scanner-status" class="text-xs md:text-sm text-white/80 flex-1 text-center sm:text-left">
          Cadrez l'article, puis appuyez sur Capturer
        </div>
        <div class="flex items-center gap-2">
          <button id="btn-switch-mode" type="button"
            class="inline-flex items-center gap-1.5 rounded-lg border border-white/20 bg-white/5 px-3 py-2 text-xs md:text-sm font-medium text-white hover:bg-white/10">
            Passer en mode Code-barres
          </button>
          <button id="btn-capture" type="button"
            class="inline-flex items-center gap-2 rounded-full bg-amber-400 hover:bg-amber-300 text-slate-900 px-5 py-2.5 text-sm font-bold shadow-lg pulse-ring">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="3"/></svg>
            Capturer
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- SETTINGS MODAL -->
  <div id="settings-modal" class="hidden fixed inset-0 z-50 items-center justify-center p-4">
    <div id="settings-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
    <div class="relative w-full max-w-lg rounded-2xl bg-white shadow-2xl overflow-hidden">
      <div class="flex items-center justify-between gap-3 px-5 py-4 border-b border-slate-200">
        <h3 class="text-base font-semibold text-slate-900">Paramètres</h3>
        <button id="btn-close-settings" type="button"
          class="inline-flex h-9 w-9 items-center justify-center rounded-lg hover:bg-slate-100">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>
      <form id="settings-form" class="p-5 space-y-5">
        <div>
          <label for="settings-apikey" class="block text-sm font-semibold text-slate-700 mb-1">Clé API Google Gemini (personnelle, optionnelle)</label>
          <div class="relative">
            <input id="settings-apikey" type="password" autocomplete="off" spellcheck="false"
              placeholder="AIzaSy… (laissez vide pour utiliser la clé serveur)"
              class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 pr-10 text-sm font-mono shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-none" />
            <button id="btn-toggle-apikey" type="button"
              class="absolute inset-y-0 right-0 flex items-center px-3 text-slate-400 hover:text-slate-600" aria-label="Afficher/Masquer la clé">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
          <div id="settings-server-status" class="mt-2 inline-flex items-center gap-1.5 rounded-full bg-slate-100 px-2.5 py-1 text-[11px] font-semibold text-slate-600">Vérification…</div>
          <p class="mt-1.5 text-xs text-slate-500">Si vide, le serveur utilise la clé de son <span class="font-mono">.env</span>. Sinon, votre clé (stockée dans ce navigateur uniquement) est prioritaire. Obtenir une clé : <a href="https://aistudio.google.com/app/apikey" target="_blank" rel="noopener" class="text-indigo-600 hover:underline">aistudio.google.com</a></p>
        </div>

        <div class="border-t border-slate-100 pt-5">
          <label for="settings-vision-key" class="block text-sm font-semibold text-slate-700 mb-1">
            Clé Google Cloud Vision <span class="text-xs font-normal text-slate-500">(optionnel, en complément)</span>
          </label>
          <div class="relative">
            <input id="settings-vision-key" type="password" autocomplete="off" spellcheck="false"
              placeholder="AIzaSy… (laissez vide pour utiliser la clé serveur)"
              class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 pr-10 text-sm font-mono shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-none" />
            <button id="btn-toggle-vision-key" type="button"
              class="absolute inset-y-0 right-0 flex items-center px-3 text-slate-400 hover:text-slate-600" aria-label="Afficher/Masquer la clé">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
          <div id="settings-vision-status" class="mt-2 inline-flex items-center gap-1.5 rounded-full bg-slate-100 px-2.5 py-1 text-[11px] font-semibold text-slate-600">Vérification…</div>
          <p class="mt-1.5 text-xs text-slate-500">Active l'enrichissement automatique : <strong>OCR</strong> (référence EAN, dimensions, prix d'étiquette), <strong>logo</strong> (marque), <strong>couleur dominante</strong>. Création : <a href="https://console.cloud.google.com/" target="_blank" rel="noopener" class="text-indigo-600 hover:underline">console.cloud.google.com</a> → activer "Cloud Vision API" → Credentials → API key.</p>
        </div>

        <div>
          <label for="settings-model" class="block text-sm font-semibold text-slate-700 mb-1">Modèle Gemini</label>
          <select id="settings-model"
            class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-none">
            <option value="gemini-2.5-flash">gemini-2.5-flash (recommandé)</option>
            <option value="gemini-2.5-pro">gemini-2.5-pro (meilleur, plus lent)</option>
            <option value="gemini-2.0-flash">gemini-2.0-flash</option>
            <option value="gemini-1.5-flash">gemini-1.5-flash</option>
          </select>
        </div>
        <div class="rounded-lg bg-slate-50 ring-1 ring-slate-200 p-3 text-xs text-slate-600">
          <div class="font-semibold text-slate-700 mb-1">Stockage</div>
          Les articles sont enregistrés dans une base <span class="font-mono text-slate-800">SQLite3</span> locale (<span class="font-mono">data/inventaire.db</span>) côté serveur. Seule votre clé Gemini est stockée dans le navigateur.
        </div>
        <div class="flex items-center justify-end gap-2 pt-2">
          <button type="button" id="btn-cancel-settings" onclick="document.getElementById('btn-close-settings').click()"
            class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">Annuler</button>
          <button type="submit"
            class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-700">Enregistrer</button>
        </div>
      </form>
    </div>
  </div>

  <!-- TOAST HOST -->
  <div id="toast-host" class="fixed top-4 right-4 z-[60] space-y-2 pointer-events-none"></div>

  <script>
    import '../scripts/app.js';
  </script>
</Layout>

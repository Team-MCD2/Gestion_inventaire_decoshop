---
import Layout from '../layouts/Layout.astro';
import ScannerModal from '../components/ScannerModal.astro';
import { RAYON_OPTIONS, MAGASINS } from '../lib/rayons.js';
---
<Layout title="Ajouter un article — Marché de Mo'">
  <main class="max-w-7xl mx-auto p-4 md:p-6 lg:p-8 space-y-6">

    <!-- Page header -->
    <div class="flex items-center justify-between gap-3">
      <div>
        <div class="text-xs font-semibold text-vert uppercase tracking-wider">Inventaire</div>
        <h1 class="text-2xl md:text-3xl font-extrabold text-slate-900 tracking-tight">Ajouter un article</h1>
      </div>
      <a href="/inventaire"
        class="inline-flex items-center gap-1.5 rounded-lg bg-white border border-slate-300 px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
        Voir l'inventaire
      </a>
    </div>

    <!-- ACTION TILES -->
    <section class="grid grid-cols-1 md:grid-cols-3 gap-3 md:gap-4">
      <button id="btn-open-photo" type="button"
        class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-vert to-vert-700 text-white p-5 md:p-6 text-left shadow-lg ring-1 ring-vert-500/30 hover:shadow-xl hover:-translate-y-0.5 transition">
        <div class="flex items-start gap-4">
          <div class="h-12 w-12 rounded-xl bg-white/15 backdrop-blur flex items-center justify-center ring-1 ring-white/25">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
          </div>
          <div class="flex-1 min-w-0">
            <div class="text-lg md:text-xl font-bold">Filmer l'article</div>
            <div class="text-sm text-white/80 mt-0.5">Analyse IA de la photo pour pré-remplir les champs</div>
          </div>
        </div>
      </button>

      <button id="btn-upload-photo" type="button"
        class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-emerald-600 to-teal-600 text-white p-5 md:p-6 text-left shadow-lg ring-1 ring-emerald-500/30 hover:shadow-xl hover:-translate-y-0.5 transition">
        <div class="flex items-start gap-4">
          <div class="h-12 w-12 rounded-xl bg-white/15 backdrop-blur flex items-center justify-center ring-1 ring-white/25">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          </div>
          <div class="flex-1 min-w-0">
            <div class="text-lg md:text-xl font-bold">Importer une photo</div>
            <div class="text-sm text-white/90 mt-0.5">Depuis votre galerie / disque, puis analyse IA</div>
          </div>
        </div>
      </button>

      <button id="btn-open-barcode" type="button"
        class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-rouge to-rouge-800 text-white p-5 md:p-6 text-left shadow-lg ring-1 ring-rouge-500/30 hover:shadow-xl hover:-translate-y-0.5 transition">
        <div class="flex items-start gap-4">
          <div class="h-12 w-12 rounded-xl bg-white/15 backdrop-blur flex items-center justify-center ring-1 ring-white/25">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 5v14"/><path d="M7 5v14"/><path d="M11 5v14"/><path d="M15 5v14"/><path d="M19 5v14"/></svg>
          </div>
          <div class="flex-1 min-w-0">
            <div class="text-lg md:text-xl font-bold">Scanner le code-barres</div>
            <div class="text-sm text-white/90 mt-0.5">EAN / UPC / QR : identification automatique</div>
          </div>
        </div>
      </button>
    </section>

    <input id="photo-upload-input" type="file" accept="image/*" class="hidden" />

    <!-- FORM -->
    <section class="bg-white rounded-2xl shadow-sm ring-1 ring-slate-200 overflow-hidden">
      <div class="flex items-center justify-between gap-3 px-5 py-4 border-b border-slate-200 bg-slate-50/60">
        <div class="flex items-center gap-2 min-w-0">
          <div class="h-2 w-2 rounded-full bg-vert"></div>
          <h2 id="form-title" class="text-base font-semibold text-slate-900 truncate">Nouvel article</h2>
        </div>
        <button id="btn-clear" type="button" class="text-sm text-slate-600 hover:text-slate-900 font-medium">Effacer</button>
      </div>

      <form id="article-form" class="p-4 md:p-6">
        <div class="grid grid-cols-1 lg:grid-cols-[220px_1fr] gap-6">
          <div class="flex lg:block">
            <div class="w-full max-w-[220px]">
              <label class="block text-xs font-semibold text-slate-600 mb-2">Photo</label>
              <div class="relative aspect-square w-full rounded-xl ring-1 ring-slate-200 bg-slate-50 overflow-hidden cursor-pointer group">
                <div id="photo-placeholder" class="absolute inset-0 flex flex-col items-center justify-center text-slate-400 p-4 text-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 mb-2 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                  <div class="text-xs font-medium">Aucune photo</div>
                  <div class="text-[11px] text-slate-400 mt-1">Filmez ou importez une photo</div>
                </div>
                <img id="photo-preview" class="hidden absolute inset-0 w-full h-full object-cover transition group-hover:scale-[1.02]" data-src="" alt="Photo de l'article" />
              </div>
            </div>
          </div>

          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4">
            <div>
              <label for="numero_article" class="block text-xs font-semibold text-slate-600 mb-1">N° article</label>
              <input id="numero_article" name="numero_article" type="text" required
                placeholder="MDM-YYMMDD-XXXXXX"
                class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-mono shadow-sm focus:border-vert focus:ring-2 focus:ring-vert-500/20 focus:outline-none" />
            </div>
            <div class="col-span-2 md:col-span-2">
              <label for="nom_produit" class="block text-xs font-semibold text-slate-600 mb-1">Nom du produit</label>
              <input id="nom_produit" name="nom_produit" type="text" autocomplete="off" placeholder="ex: Riz Basmati 5kg, Huile d'olive, Banane plantain…"
                class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-vert focus:ring-2 focus:ring-vert-500/20 focus:outline-none" />
            </div>
            <div>
              <label for="rayon" class="block text-xs font-semibold text-slate-600 mb-1">Rayon</label>
              <select id="rayon" name="rayon"
                class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-vert focus:ring-2 focus:ring-vert-500/20 focus:outline-none">
                <option value="">Choisir un rayon</option>
                {RAYON_OPTIONS.map(opt => (
                  <option value={opt.slug}>{opt.label}</option>
                ))}
              </select>
            </div>
            <div>
              <label for="code_barres" class="block text-xs font-semibold text-slate-600 mb-1">Code-barres (EAN/UPC)</label>
              <div class="relative">
                <input id="code_barres" name="code_barres" type="text" autocomplete="off" placeholder="Tapez ou scannez…"
                  class="w-full rounded-lg border border-slate-300 bg-white pl-3 pr-11 py-2 text-sm font-mono shadow-sm focus:border-vert focus:ring-2 focus:ring-vert-500/20 focus:outline-none" />
                <button id="btn-scan-barcode-field" type="button"
                  title="Scanner le code-barres avec la caméra"
                  aria-label="Scanner le code-barres avec la caméra"
                  class="absolute inset-y-0 right-0 my-1 mr-1 inline-flex items-center justify-center w-8 rounded-md text-slate-500 hover:text-vert hover:bg-vert-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-vert-500">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 5v14"/><path d="M7 5v14"/><path d="M11 5v14"/><path d="M15 5v14"/><path d="M19 5v14"/></svg>
                </button>
              </div>
              <p class="mt-1 text-[11px] text-slate-500">Saisie manuelle ou clic sur l'icône pour scanner.</p>
            </div>
            <div>
              <label for="marque" class="block text-xs font-semibold text-slate-600 mb-1">Marque</label>
              <input id="marque" name="marque" type="text" autocomplete="off" placeholder="ex: Maggi, Ferrero, Panzani…"
                class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-vert focus:ring-2 focus:ring-vert-500/20 focus:outline-none" />
            </div>
            <div>
              <label for="format" class="block text-xs font-semibold text-slate-600 mb-1">Format / Poids</label>
              <input id="format" name="format" type="text" autocomplete="off" placeholder="ex: 500g, 1L, Pack de 6…"
                class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-vert focus:ring-2 focus:ring-vert-500/20 focus:outline-none" />
            </div>
            <div>
              <label for="dlc" class="block text-xs font-semibold text-slate-600 mb-1">Date limite (DLC)</label>
              <input id="dlc" name="dlc" type="text" autocomplete="off" placeholder="ex: 24/12/2026"
                class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-vert focus:ring-2 focus:ring-vert-500/20 focus:outline-none" />
            </div>
            <div>
              <label for="magasin" class="block text-xs font-semibold text-slate-600 mb-1">Magasin</label>
              <select id="magasin" name="magasin"
                class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-vert focus:ring-2 focus:ring-vert-500/20 focus:outline-none">
                {MAGASINS.map(m => (
                  <option value={m.slug}>{m.label}</option>
                ))}
              </select>
            </div>
            <div class="col-span-2 md:col-span-3 lg:col-span-4">
              <label for="description" class="block text-xs font-semibold text-slate-600 mb-1">Notes / Description</label>
              <textarea id="description" name="description" rows="2"
                class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-vert focus:ring-2 focus:ring-vert-500/20 focus:outline-none resize-none"></textarea>
            </div>

            <div class="col-span-2 md:col-span-3 lg:col-span-4 p-3 md:p-4 rounded-xl bg-slate-50 ring-1 ring-slate-200">
              <label for="prix_vente" class="block text-xs font-semibold text-slate-600 mb-1">Prix de vente (€)</label>
              <input id="prix_vente" name="prix_vente" type="number" min="0" step="0.01" inputmode="decimal"
                class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm tabular-nums shadow-sm focus:border-vert focus:ring-2 focus:ring-vert-500/20 focus:outline-none" />
            </div>

            <div class="col-span-2 md:col-span-3 lg:col-span-4 grid grid-cols-3 gap-3 md:gap-4 p-3 md:p-4 rounded-xl bg-slate-50 ring-1 ring-slate-200">
              <div>
                <label for="quantite_initiale" class="block text-xs font-semibold text-slate-600 mb-1">Quantité initiale</label>
                <input id="quantite_initiale" name="quantite_initiale" type="number" min="0" step="1" value="1" inputmode="numeric"
                  class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm tabular-nums shadow-sm focus:border-vert focus:ring-2 focus:ring-vert-500/20 focus:outline-none" />
              </div>
              <div>
                <label for="quantite" class="block text-xs font-semibold text-slate-600 mb-1">Quantité actuelle</label>
                <input id="quantite" name="quantite" type="number" min="0" step="1" value="1" inputmode="numeric"
                  class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm tabular-nums shadow-sm focus:border-vert focus:ring-2 focus:ring-vert-500/20 focus:outline-none" />
              </div>
              <div>
                <label for="seuil" class="block text-xs font-semibold text-slate-600 mb-1">Seuil réappro.</label>
                <input id="seuil" name="seuil" type="number" min="0" step="1" value="5" inputmode="numeric"
                  class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm tabular-nums shadow-sm focus:border-vert focus:ring-2 focus:ring-vert-500/20 focus:outline-none" />
              </div>
            </div>

          </div>
        </div>

        <div class="mt-6 flex flex-col-reverse sm:flex-row sm:items-center sm:justify-end gap-2 pt-4 border-t border-slate-100">
          <button type="submit" id="btn-submit"
            class="inline-flex justify-center items-center gap-2 rounded-lg bg-vert px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-vert-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-vert-500 focus-visible:ring-offset-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
            Ajouter à l'inventaire
          </button>
        </div>
      </form>
    </section>
  </main>

  <ScannerModal />

  <script>
    import '../scripts/app.js';
  </script>
</Layout>

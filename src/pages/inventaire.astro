---
import Layout from '../layouts/Layout.astro';
import EditModal from '../components/EditModal.astro';
import { RAYON_OPTIONS, MAGASINS } from '../lib/rayons.js';

const isAdmin = Astro.locals.userRole === 'admin';
---
<Layout title="Inventaire — Marché de Mo'">
  <main class="max-w-7xl mx-auto p-4 md:p-6 lg:p-8 space-y-6">

    <!-- Page header -->
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <div class="text-xs font-semibold text-vert uppercase tracking-wider">Stock</div>
        <h1 class="text-2xl md:text-3xl font-extrabold text-slate-900 tracking-tight flex items-center gap-3">
          Inventaire
          <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700 ring-1 ring-emerald-200">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
            <span id="inventory-count">…</span> articles
          </span>
        </h1>
      </div>
      <div class="flex flex-wrap items-center gap-2">
        <a href="/ajouter"
          class="inline-flex items-center gap-1.5 rounded-lg bg-vert px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-vert-700 print:hidden">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
          Ajouter un article
        </a>
      </div>
    </div>

    <!-- Récapitulatif inventaire -->
    <section id="inventory-recap" class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
      <div class="bg-white rounded-2xl ring-1 ring-slate-200 p-4 md:p-5">
        <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Valeur totale stock</div>
        <div id="recap-value" class="mt-1.5 text-2xl font-extrabold text-slate-900 tabular-nums">—</div>
        <div class="text-[11px] text-slate-400 mt-0.5">Prix vente × quantité</div>
      </div>
      <div class="bg-white rounded-2xl ring-1 ring-slate-200 p-4 md:p-5">
        <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Unités en stock</div>
        <div id="recap-units" class="mt-1.5 text-2xl font-extrabold text-emerald-600 tabular-nums">—</div>
        <div class="text-[11px] text-slate-400 mt-0.5">Quantité totale</div>
      </div>
      <div class="bg-white rounded-2xl ring-1 ring-slate-200 p-4 md:p-5">
        <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Stock faible</div>
        <div id="recap-low" class="mt-1.5 text-2xl font-extrabold text-amber-600 tabular-nums">—</div>
        <div class="text-[11px] text-slate-400 mt-0.5">À réapprovisionner</div>
      </div>
      <div class="bg-white rounded-2xl ring-1 ring-slate-200 p-4 md:p-5">
        <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider">En rupture</div>
        <div id="recap-out" class="mt-1.5 text-2xl font-extrabold text-red-600 tabular-nums">—</div>
        <div class="text-[11px] text-slate-400 mt-0.5">Quantité = 0</div>
      </div>

      <!-- Dates utiles - full width -->
      <div class="col-span-2 md:col-span-4 bg-white rounded-2xl ring-1 ring-slate-200 px-4 md:px-5 py-3 flex flex-wrap gap-x-8 gap-y-1 text-xs text-slate-500">
        <div><span class="font-semibold text-slate-700">Début inventaire :</span> <span id="recap-date-start">—</span></div>
        <div><span class="font-semibold text-slate-700">Dernier ajout :</span> <span id="recap-date-last">—</span></div>
        <div><span class="font-semibold text-slate-700">Dernière mise à jour :</span> <span id="recap-date-updated">—</span></div>
      </div>
    </section>

    <!-- Toolbar : recherche + filtres + exports -->
    <section class="bg-white rounded-2xl shadow-sm ring-1 ring-slate-200 p-4 md:p-5 print:hidden">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-4">
        <div class="grid grid-cols-1 md:grid-cols-[1fr_auto_auto_auto] gap-3 md:items-center">
          <div class="relative">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 absolute left-3 top-1/2 -translate-y-1/2 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            <input id="inventory-search" type="search" placeholder="Rechercher par numéro, nom, code-barres, marque, description…"
              class="w-full rounded-lg border border-slate-300 bg-white pl-9 pr-3 py-2 text-sm shadow-sm focus:border-vert focus:ring-2 focus:ring-vert-500/20 focus:outline-none" />
          </div>
          <select id="inventory-filter-rayon"
            class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-vert focus:ring-2 focus:ring-vert-500/20 focus:outline-none">
            <option value="">Tous les rayons</option>
            {RAYON_OPTIONS.map(opt => (
              <option value={opt.slug}>{opt.label}</option>
            ))}
          </select>
          <select id="inventory-filter-magasin"
            class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-vert focus:ring-2 focus:ring-vert-500/20 focus:outline-none">
            <option value="">Tous les magasins</option>
            {MAGASINS.filter(m => m.slug).map(m => (
              <option value={m.slug}>{m.label}</option>
            ))}
          </select>
          <select id="inventory-filter-status"
            class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-vert focus:ring-2 focus:ring-vert-500/20 focus:outline-none">
            <option value="">Tous les statuts</option>
            <option value="en_stock">En stock</option>
            <option value="stock_faible">Stock faible</option>
            <option value="rupture">Rupture</option>
          </select>
        </div>

        <div class="flex flex-wrap items-center gap-2 justify-end">
          {isAdmin && (
            <>
              <button id="btn-export-backup" type="button"
                class="inline-flex items-center gap-1.5 rounded-lg bg-vert px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-vert-700"
                title="Exporter toute la base de données (format JSON)">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                Backup
              </button>
            </>
          )}
          <button id="btn-export-csv" type="button"
            class="inline-flex items-center gap-1.5 rounded-lg bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
            CSV
          </button>
          <button id="btn-export-pdf" type="button"
            class="inline-flex items-center gap-1.5 rounded-lg bg-red-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-700">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>
            PDF
          </button>
          {isAdmin && (
            <>
              <button id="btn-import-csv" type="button"
                class="inline-flex items-center gap-1.5 rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50"
                title="Importer des articles depuis un fichier CSV">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                Import
              </button>
              <input type="file" id="csv-import-input" accept=".csv" class="hidden" />

              <button id="btn-clear-all" type="button"
                class="inline-flex items-center gap-1.5 rounded-lg border border-red-200 bg-white px-3 py-2 text-sm font-medium text-red-600 hover:bg-red-50">
                Vider
              </button>
            </>
          )}
        </div>
      </div>
    </section>

    <!-- INVENTORY TABLE -->
    <section class="bg-white rounded-2xl shadow-sm ring-1 ring-slate-200 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full text-sm">
          <thead class="bg-slate-50 text-[11px] uppercase tracking-wider text-slate-500 border-b border-slate-200">
            <tr>
              <th class="px-3 py-2 text-left font-semibold">N° article</th>
              <th class="px-3 py-2 text-left font-semibold">Photo</th>
              <th class="px-3 py-2 text-left font-semibold">Nom produit</th>
              <th class="px-3 py-2 text-left font-semibold">Rayon</th>
              <th class="px-3 py-2 text-left font-semibold">Marque</th>
              <th class="px-3 py-2 text-left font-semibold">DLC</th>
              <th class="px-3 py-2 text-left font-semibold">Format</th>
              <th class="px-3 py-2 text-left font-semibold">Magasin</th>
              <th class="px-3 py-2 text-left font-semibold">Description</th>
              <th class="px-3 py-2 text-right font-semibold">P. vente</th>
              <th class="px-3 py-2 text-left font-semibold">Code-barres</th>
              <th class="px-3 py-2 text-right font-semibold">Qté init.</th>
              <th class="px-3 py-2 text-right font-semibold">Qté</th>
              <th class="px-3 py-2 text-left font-semibold">Statut</th>
              <th class="px-3 py-2 text-right font-semibold print:hidden">Actions</th>
            </tr>
          </thead>
          <tbody id="inventory-tbody" class="divide-y divide-slate-100 bg-white"></tbody>
        </table>
        <div id="inventory-loading" class="hidden py-16 px-6 text-center text-slate-400">
          <div class="h-10 w-10 mx-auto mb-3 rounded-full border-4 border-slate-200 border-t-indigo-500 animate-spin"></div>
          <p class="text-sm font-medium">Chargement de l'inventaire…</p>
        </div>
        <div id="inventory-empty" class="hidden py-16 px-6 text-center text-slate-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto mb-3 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7h-3V4a1 1 0 0 0-1-1H8a1 1 0 0 0-1 1v3H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1V8a1 1 0 0 0-1-1z"/><path d="M9 7V5h6v2"/></svg>
          <p class="text-sm font-medium">Données indisponibles</p>
          <p class="text-xs text-slate-400 mt-1">Aucun article ne correspond à votre recherche ou l'inventaire est vide.</p>
        </div>
      </div>
    </section>
  </main>

  <EditModal />

  <!-- Modale de confirmation pour "Vider tout l'inventaire" — action irréversible -->
  <div id="confirm-clear-modal" class="hidden fixed inset-0 z-50 items-center justify-center p-4">
    <div id="confirm-clear-backdrop" class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm"></div>
    <div class="relative w-full max-w-md rounded-2xl bg-white shadow-2xl ring-1 ring-slate-200 overflow-hidden">
      <div class="px-6 pt-6 pb-4">
        <div class="flex items-start gap-4">
          <div class="h-12 w-12 shrink-0 rounded-full bg-red-100 flex items-center justify-center ring-4 ring-red-50">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-red-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="text-lg font-bold text-slate-900">Vider tout l'inventaire ?</h3>
            <p class="mt-1 text-sm text-slate-600">
              Vous êtes sur le point de supprimer <strong class="text-slate-900"><span id="confirm-clear-count">0</span> article(s)</strong>.
              Cette action est <strong class="text-red-600">irréversible</strong> : aucune sauvegarde ne sera conservée.
            </p>
          </div>
        </div>

        <div class="mt-5">
          <label for="confirm-clear-input" class="block text-xs font-semibold text-slate-700 mb-1.5">
            Pour confirmer, tapez <span class="font-mono font-bold text-red-600">VIDER</span> ci-dessous :
          </label>
          <input id="confirm-clear-input" type="text" autocomplete="off" spellcheck="false"
            placeholder="VIDER"
            class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-mono uppercase tracking-wider shadow-sm focus:border-red-500 focus:ring-2 focus:ring-red-500/20 focus:outline-none" />
        </div>
      </div>

      <div class="flex items-center justify-end gap-2 px-6 py-4 bg-slate-50 border-t border-slate-200">
        <button id="btn-confirm-clear-cancel" type="button"
          class="inline-flex items-center justify-center rounded-lg bg-white border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100">
          Annuler
        </button>
        <button id="btn-confirm-clear-ok" type="button" disabled
          class="inline-flex items-center gap-1.5 rounded-lg bg-red-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-700 disabled:bg-red-300 disabled:cursor-not-allowed">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
          Oui, tout supprimer
        </button>
      </div>
    </div>
  </div>

  <style is:global>
    @media print {
      @page { size: A4 landscape; margin: 8mm; }
      body { background: white !important; }
      header, footer, nav, .navbar, .print\:hidden { display: none !important; }
      main { padding: 0 !important; max-width: 100% !important; }
      #inventory-recap { display: grid !important; grid-template-columns: repeat(4, 1fr) !important; }
    }
  </style>

  <script>
    import '../scripts/app.js';
  </script>
</Layout>

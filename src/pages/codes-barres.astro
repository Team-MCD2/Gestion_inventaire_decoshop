---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Générer des codes-barres — DECO SHOP">
  <main class="max-w-7xl mx-auto p-4 md:p-6 lg:p-8 space-y-6">

    <!-- Page header -->
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <div class="text-xs font-semibold text-fuchsia-600 uppercase tracking-wider">Inventaire</div>
        <h1 class="text-2xl md:text-3xl font-extrabold text-slate-900 tracking-tight">Générer des codes-barres</h1>
        <p class="text-sm text-slate-600 mt-1">Codes EAN-13 conformes au standard <strong>GS1 France</strong> (préfixe 300-379) avec checksum valide.</p>
      </div>
      <a href="/inventaire"
        class="inline-flex items-center gap-1.5 rounded-lg bg-white border border-slate-300 px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
        Retour
      </a>
    </div>

    <!-- KPI strip -->
    <section class="grid grid-cols-1 sm:grid-cols-3 gap-3 md:gap-4">
      <div class="bg-white rounded-2xl ring-1 ring-slate-200 p-4 md:p-5">
        <div class="text-xs font-medium text-slate-500 uppercase tracking-wider">Total articles</div>
        <div id="kpi-total" class="mt-1 text-2xl md:text-3xl font-extrabold text-slate-900 tabular-nums">—</div>
      </div>
      <div class="bg-white rounded-2xl ring-1 ring-slate-200 p-4 md:p-5">
        <div class="text-xs font-medium text-slate-500 uppercase tracking-wider">Avec code-barres</div>
        <div id="kpi-with" class="mt-1 text-2xl md:text-3xl font-extrabold text-emerald-600 tabular-nums">—</div>
      </div>
      <div class="bg-white rounded-2xl ring-1 ring-slate-200 p-4 md:p-5">
        <div class="text-xs font-medium text-slate-500 uppercase tracking-wider">Sans code-barres</div>
        <div id="kpi-without" class="mt-1 text-2xl md:text-3xl font-extrabold text-fuchsia-600 tabular-nums">—</div>
      </div>
    </section>

    <!-- Action bar -->
    <section class="bg-white rounded-2xl shadow-sm ring-1 ring-slate-200 p-4 md:p-5">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div class="min-w-0">
          <h2 class="text-base font-semibold text-slate-900">Articles sans code-barres</h2>
          <p id="missing-summary" class="text-sm text-slate-500 mt-0.5">Chargement…</p>
        </div>
        <div class="flex flex-wrap items-center gap-2">
          <button id="btn-refresh" type="button"
            class="inline-flex items-center gap-1.5 rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-3-6.7L21 8"/><path d="M21 3v5h-5"/></svg>
            Rafraîchir
          </button>
          <button id="btn-generate" type="button" disabled
            class="inline-flex items-center gap-2 rounded-lg bg-fuchsia-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-fuchsia-700 disabled:bg-slate-300 disabled:cursor-not-allowed">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 5v14"/><path d="M7 5v14"/><path d="M11 5v14"/><path d="M15 5v14"/><path d="M19 5v14"/></svg>
            Générer les codes-barres
          </button>
        </div>
      </div>
    </section>

    <!-- Loading state -->
    <section id="loading" class="hidden bg-white rounded-2xl shadow-sm ring-1 ring-slate-200 p-10 text-center">
      <div class="h-10 w-10 mx-auto mb-3 rounded-full border-4 border-slate-200 border-t-fuchsia-500 animate-spin"></div>
      <p class="text-sm font-medium text-slate-600">Chargement des articles…</p>
    </section>

    <!-- Empty state (no missing barcodes) -->
    <section id="empty" class="hidden bg-white rounded-2xl shadow-sm ring-1 ring-slate-200 p-10 md:p-14 text-center">
      <div class="mx-auto h-16 w-16 rounded-2xl bg-emerald-50 ring-1 ring-emerald-200 flex items-center justify-center text-emerald-600 mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
      </div>
      <h2 class="text-lg font-semibold text-slate-900">Tout est en ordre</h2>
      <p class="text-sm text-slate-500 mt-1 max-w-md mx-auto">Tous vos articles ont déjà un code-barres. Rien à générer pour le moment.</p>
    </section>

    <!-- Table : articles à traiter -->
    <section id="missing-section" class="hidden bg-white rounded-2xl shadow-sm ring-1 ring-slate-200 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full text-sm">
          <thead class="bg-slate-50 text-[11px] uppercase tracking-wider text-slate-500 border-b border-slate-200">
            <tr>
              <th class="px-3 py-2 text-left font-semibold w-12">
                <input id="check-all" type="checkbox" class="rounded border-slate-300" checked />
              </th>
              <th class="px-3 py-2 text-left font-semibold">N° article (série)</th>
              <th class="px-3 py-2 text-left font-semibold">Photo</th>
              <th class="px-3 py-2 text-left font-semibold">Description</th>
              <th class="px-3 py-2 text-left font-semibold">Marque</th>
              <th class="px-3 py-2 text-left font-semibold">Catégorie</th>
              <th class="px-3 py-2 text-right font-semibold">Qté</th>
            </tr>
          </thead>
          <tbody id="missing-tbody" class="divide-y divide-slate-100 bg-white"></tbody>
        </table>
      </div>
    </section>

    <!-- Generated labels (after generation) -->
    <section id="labels-section" class="hidden">
      <div class="flex flex-wrap items-center justify-between gap-3 mb-4 print:hidden">
        <div>
          <h2 class="text-lg font-bold text-slate-900">Étiquettes générées</h2>
          <p class="text-sm text-slate-500 mt-0.5">Aperçu prêt pour l'impression. Format A4, ~24 étiquettes par page.</p>
        </div>
        <div class="flex flex-wrap items-center gap-2">
          <button id="btn-print" type="button"
            class="inline-flex items-center gap-1.5 rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-700">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9V2h12v7"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8" rx="1"/></svg>
            Imprimer
          </button>
          <button id="btn-download-pdf" type="button"
            class="inline-flex items-center gap-1.5 rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
            Télécharger PDF
          </button>
        </div>
      </div>

      <!-- Print-friendly grid of labels -->
      <div id="labels-grid" class="bg-white p-4 md:p-6 rounded-2xl shadow-sm ring-1 ring-slate-200 print:rounded-none print:shadow-none print:ring-0 print:p-0">
        <!-- Filled by codes-barres.js -->
      </div>
    </section>

  </main>

  <!-- Print stylesheet : 24 étiquettes par page A4 -->
  <style is:global>
    @media print {
      @page { size: A4; margin: 8mm; }
      body { background: white !important; }
      header, footer, nav, .navbar, [data-no-print] { display: none !important; }
      main { padding: 0 !important; max-width: 100% !important; }
      #labels-grid {
        display: grid !important;
        grid-template-columns: repeat(3, 1fr) !important;
        gap: 4mm !important;
      }
      .label-card {
        break-inside: avoid;
        page-break-inside: avoid;
        border: 1px solid #cbd5e1 !important;
        padding: 4mm !important;
        text-align: center;
      }
      .label-card svg { width: 100% !important; height: auto !important; }
    }
    .label-card { break-inside: avoid; }
  </style>

  <script>
    import '../scripts/codes-barres.js';
  </script>
</Layout>

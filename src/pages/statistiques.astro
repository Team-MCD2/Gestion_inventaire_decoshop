---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Statistiques — DECO SHOP">
  <main class="max-w-7xl mx-auto p-4 md:p-6 lg:p-8 space-y-6">

    <div>
      <div class="text-xs font-semibold text-violet-600 uppercase tracking-wider">Tableau de bord</div>
      <h1 class="text-2xl md:text-3xl font-extrabold text-slate-900 tracking-tight">Statistiques</h1>
      <p class="text-sm text-slate-600 mt-1">Vue d'ensemble de votre stock. Les ventes Shopify s'afficheront automatiquement dès la connexion à la base.</p>
    </div>

    <!-- KPI cards -->
    <section class="grid grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4">
      <div class="bg-white rounded-2xl ring-1 ring-slate-200 p-4 md:p-5">
        <div class="flex items-center justify-between">
          <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Articles</div>
          <div class="h-8 w-8 rounded-lg bg-indigo-100 text-indigo-600 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          </div>
        </div>
        <div class="mt-2 text-3xl md:text-4xl font-extrabold text-slate-900 tabular-nums" id="kpi-total">—</div>
        <div class="text-xs text-slate-500 mt-1"><span id="kpi-units">—</span> unités au total</div>
      </div>

      <div class="bg-white rounded-2xl ring-1 ring-slate-200 p-4 md:p-5">
        <div class="flex items-center justify-between">
          <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Valeur stock</div>
          <div class="h-8 w-8 rounded-lg bg-emerald-100 text-emerald-600 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
        </div>
        <div class="mt-2 text-3xl md:text-4xl font-extrabold text-slate-900 tabular-nums" id="kpi-value">—</div>
        <div class="text-xs text-slate-500 mt-1">Prix de vente × quantité</div>
      </div>

      <div class="bg-white rounded-2xl ring-1 ring-slate-200 p-4 md:p-5">
        <div class="flex items-center justify-between">
          <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Stock faible</div>
          <div class="h-8 w-8 rounded-lg bg-amber-100 text-amber-600 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.46 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
          </div>
        </div>
        <div class="mt-2 text-3xl md:text-4xl font-extrabold text-amber-600 tabular-nums" id="kpi-low">—</div>
        <div class="text-xs text-slate-500 mt-1">À réapprovisionner</div>
      </div>

      <div class="bg-white rounded-2xl ring-1 ring-slate-200 p-4 md:p-5">
        <div class="flex items-center justify-between">
          <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider">En rupture</div>
          <div class="h-8 w-8 rounded-lg bg-red-100 text-red-600 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m4.93 4.93 14.14 14.14"/></svg>
          </div>
        </div>
        <div class="mt-2 text-3xl md:text-4xl font-extrabold text-red-600 tabular-nums" id="kpi-out">—</div>
        <div class="text-xs text-slate-500 mt-1">Quantité = 0</div>
      </div>
    </section>

    <!-- Charts row -->
    <section class="grid grid-cols-1 lg:grid-cols-2 gap-4 md:gap-6">

      <!-- Donut catégorie -->
      <div class="bg-white rounded-2xl shadow-sm ring-1 ring-slate-200 p-4 md:p-5">
        <h2 class="text-sm font-semibold text-slate-900 mb-3">Répartition par catégorie</h2>
        <div class="relative h-64 md:h-72">
          <canvas id="chart-categories"></canvas>
        </div>
      </div>

      <!-- Bar valeur par catégorie -->
      <div class="bg-white rounded-2xl shadow-sm ring-1 ring-slate-200 p-4 md:p-5">
        <h2 class="text-sm font-semibold text-slate-900 mb-3">Valeur du stock par catégorie</h2>
        <div class="relative h-64 md:h-72">
          <canvas id="chart-value-by-cat"></canvas>
        </div>
      </div>
    </section>

    <!-- Top 10 + status pie -->
    <section class="grid grid-cols-1 lg:grid-cols-3 gap-4 md:gap-6">

      <!-- Top 10 par valeur -->
      <div class="lg:col-span-2 bg-white rounded-2xl shadow-sm ring-1 ring-slate-200 p-4 md:p-5">
        <h2 class="text-sm font-semibold text-slate-900 mb-3">Top 10 articles par valeur de stock</h2>
        <div id="top-list" class="space-y-2">
          <!-- Populated by JS -->
        </div>
        <div id="top-empty" class="hidden py-8 text-center text-sm text-slate-400">Aucun article en stock</div>
      </div>

      <!-- Status pie -->
      <div class="bg-white rounded-2xl shadow-sm ring-1 ring-slate-200 p-4 md:p-5">
        <h2 class="text-sm font-semibold text-slate-900 mb-3">Statut du stock</h2>
        <div class="relative h-64">
          <canvas id="chart-status"></canvas>
        </div>
      </div>
    </section>

    <!-- Shopify placeholders -->
    <section class="bg-gradient-to-br from-slate-50 to-violet-50 rounded-2xl ring-1 ring-violet-200 p-5 md:p-6">
      <div class="flex items-start justify-between gap-3 mb-4">
        <div>
          <div class="inline-flex items-center gap-2 px-2.5 py-0.5 rounded-full bg-violet-100 text-violet-700 text-[11px] font-semibold ring-1 ring-violet-200 uppercase tracking-wider">
            Bientôt — connexion Shopify
          </div>
          <h2 class="mt-2 text-base font-bold text-slate-900">Statistiques de ventes</h2>
          <p class="text-sm text-slate-600 mt-1 max-w-2xl">
            Top ventes, panier moyen, chiffre d'affaires, articles à booster… s'activeront automatiquement dès que la base Supabase recevra les commandes Shopify.
          </p>
        </div>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 opacity-60 select-none">
        <div class="bg-white rounded-xl ring-1 ring-slate-200 p-4">
          <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Top vendu</div>
          <div class="mt-2 text-xl font-extrabold text-slate-300 tabular-nums">— —</div>
        </div>
        <div class="bg-white rounded-xl ring-1 ring-slate-200 p-4">
          <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider">CA 30j</div>
          <div class="mt-2 text-xl font-extrabold text-slate-300 tabular-nums">— —</div>
        </div>
        <div class="bg-white rounded-xl ring-1 ring-slate-200 p-4">
          <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Panier moyen</div>
          <div class="mt-2 text-xl font-extrabold text-slate-300 tabular-nums">— —</div>
        </div>
        <div class="bg-white rounded-xl ring-1 ring-slate-200 p-4">
          <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Conversion</div>
          <div class="mt-2 text-xl font-extrabold text-slate-300 tabular-nums">— —</div>
        </div>
      </div>
    </section>

  </main>

  <script>
    import '../scripts/stats.js';
  </script>
</Layout>

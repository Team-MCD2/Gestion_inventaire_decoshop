---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Statistiques — DECO SHOP">
  <main class="max-w-7xl mx-auto p-4 md:p-6 lg:p-8 space-y-6">

    <div class="flex items-start justify-between gap-3">
      <div>
        <div class="text-xs font-semibold text-violet-600 uppercase tracking-wider">Tableau de bord</div>
        <h1 class="text-2xl md:text-3xl font-extrabold text-slate-900 tracking-tight">Statistiques</h1>
        <p class="text-sm text-slate-600 mt-1">Vue d'ensemble de votre stock en temps réel.</p>
      </div>
      <!-- Pill loader visible only while fetching -->
      <div id="stats-loader" class="inline-flex items-center gap-2 rounded-full bg-violet-50 px-3 py-1.5 text-xs font-semibold text-violet-700 ring-1 ring-violet-200">
        <div class="h-3 w-3 rounded-full border-2 border-violet-200 border-t-violet-600 animate-spin"></div>
        <span>Chargement…</span>
      </div>
    </div>

    <!-- KPI cards -->
    <section class="grid grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4">
      <a href="/inventaire" class="bg-white rounded-2xl ring-1 ring-slate-200 p-4 md:p-5 hover:ring-indigo-500 hover:shadow-md transition group">
        <div class="flex items-center justify-between">
          <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider group-hover:text-indigo-600 transition">Articles</div>
          <div class="h-8 w-8 rounded-lg bg-indigo-100 text-indigo-600 flex items-center justify-center group-hover:bg-indigo-600 group-hover:text-white transition">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          </div>
        </div>
        <div class="kpi-skel mt-2 h-9 md:h-10 w-20 rounded-lg bg-slate-200 animate-pulse"></div>
        <div class="kpi-val mt-2 text-3xl md:text-4xl font-extrabold text-slate-900 tabular-nums hidden" id="kpi-total">—</div>
        <div class="kpi-sub-skel mt-2 h-3 w-28 rounded bg-slate-100 animate-pulse"></div>
        <div class="kpi-sub text-xs text-slate-500 mt-1 hidden"><span id="kpi-units">—</span> unités au total</div>
      </a>

      <a href="/inventaire" class="bg-white rounded-2xl ring-1 ring-slate-200 p-4 md:p-5 hover:ring-emerald-500 hover:shadow-md transition group">
        <div class="flex items-center justify-between">
          <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider group-hover:text-emerald-600 transition">Valeur stock</div>
          <div class="h-8 w-8 rounded-lg bg-emerald-100 text-emerald-600 flex items-center justify-center group-hover:bg-emerald-600 group-hover:text-white transition">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
        </div>
        <div class="kpi-skel mt-2 h-9 md:h-10 w-28 rounded-lg bg-slate-200 animate-pulse"></div>
        <div class="kpi-val mt-2 text-3xl md:text-4xl font-extrabold text-slate-900 tabular-nums hidden" id="kpi-value">—</div>
        <div class="kpi-sub-skel mt-2 h-3 w-32 rounded bg-slate-100 animate-pulse"></div>
        <div class="kpi-sub text-xs text-slate-500 mt-1 hidden">Prix de vente × quantité</div>
      </a>

      <a href="/inventaire?status=stock_faible" class="bg-white rounded-2xl ring-1 ring-slate-200 p-4 md:p-5 hover:ring-amber-500 hover:shadow-md transition group">
        <div class="flex items-center justify-between">
          <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider group-hover:text-amber-600 transition">Stock faible</div>
          <div class="h-8 w-8 rounded-lg bg-amber-100 text-amber-600 flex items-center justify-center group-hover:bg-amber-600 group-hover:text-white transition">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.46 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
          </div>
        </div>
        <div class="kpi-skel mt-2 h-9 md:h-10 w-16 rounded-lg bg-slate-200 animate-pulse"></div>
        <div class="kpi-val mt-2 text-3xl md:text-4xl font-extrabold text-amber-600 tabular-nums hidden" id="kpi-low">—</div>
        <div class="kpi-sub-skel mt-2 h-3 w-24 rounded bg-slate-100 animate-pulse"></div>
        <div class="kpi-sub text-xs text-slate-500 mt-1 hidden">À réapprovisionner</div>
      </a>

      <a href="/inventaire?status=rupture" class="bg-white rounded-2xl ring-1 ring-slate-200 p-4 md:p-5 hover:ring-red-500 hover:shadow-md transition group">
        <div class="flex items-center justify-between">
          <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider group-hover:text-red-600 transition">En rupture</div>
          <div class="h-8 w-8 rounded-lg bg-red-100 text-red-600 flex items-center justify-center group-hover:bg-red-600 group-hover:text-white transition">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m4.93 4.93 14.14 14.14"/></svg>
          </div>
        </div>
        <div class="kpi-skel mt-2 h-9 md:h-10 w-16 rounded-lg bg-slate-200 animate-pulse"></div>
        <div class="kpi-val mt-2 text-3xl md:text-4xl font-extrabold text-red-600 tabular-nums hidden" id="kpi-out">—</div>
        <div class="kpi-sub-skel mt-2 h-3 w-24 rounded bg-slate-100 animate-pulse"></div>
        <div class="kpi-sub text-xs text-slate-500 mt-1 hidden">Quantité = 0</div>
      </a>
    </section>

    <!-- Charts row -->
    <section class="grid grid-cols-1 lg:grid-cols-2 gap-4 md:gap-6">

      <!-- Donut catégorie -->
      <div class="bg-white rounded-2xl shadow-sm ring-1 ring-slate-200 p-4 md:p-5">
        <h2 class="text-sm font-semibold text-slate-900 mb-3">Répartition par catégorie</h2>
        <div class="relative h-64 md:h-72">
          <canvas id="chart-categories"></canvas>
          <div class="chart-loader absolute inset-0 flex flex-col items-center justify-center bg-white/60 backdrop-blur-sm rounded-lg">
            <div class="h-8 w-8 rounded-full border-[3px] border-slate-200 border-t-violet-500 animate-spin mb-2"></div>
            <div class="text-xs text-slate-500 font-medium">Chargement…</div>
          </div>
        </div>
      </div>

      <!-- Bar valeur par catégorie -->
      <div class="bg-white rounded-2xl shadow-sm ring-1 ring-slate-200 p-4 md:p-5">
        <h2 class="text-sm font-semibold text-slate-900 mb-3">Valeur du stock par catégorie</h2>
        <div class="relative h-64 md:h-72">
          <canvas id="chart-value-by-cat"></canvas>
          <div class="chart-loader absolute inset-0 flex flex-col items-center justify-center bg-white/60 backdrop-blur-sm rounded-lg">
            <div class="h-8 w-8 rounded-full border-[3px] border-slate-200 border-t-violet-500 animate-spin mb-2"></div>
            <div class="text-xs text-slate-500 font-medium">Chargement…</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Top 10 + status pie -->
    <section class="grid grid-cols-1 lg:grid-cols-3 gap-4 md:gap-6">

      <!-- Top 10 par valeur — cliquable -->
      <div class="lg:col-span-2 bg-white rounded-2xl shadow-sm ring-1 ring-slate-200 p-4 md:p-5">
        <h2 class="text-sm font-semibold text-slate-900 mb-1">Top 10 articles par valeur de stock</h2>
        <p class="text-xs text-slate-400 mb-3">Cliquez sur un article pour voir sa fiche détaillée.</p>
        <div id="top-list" class="space-y-2">
          <!-- Skeleton rows shown until data is loaded; replaced by stats.js -->
          <div class="top-skel space-y-2">
            <div class="flex items-center gap-3 p-2">
              <div class="h-7 w-7 rounded-md bg-slate-200 animate-pulse"></div>
              <div class="h-10 w-10 rounded-md bg-slate-200 animate-pulse"></div>
              <div class="flex-1 space-y-2">
                <div class="h-3 w-1/2 rounded bg-slate-200 animate-pulse"></div>
                <div class="h-1.5 w-full rounded-full bg-slate-100 animate-pulse"></div>
              </div>
              <div class="space-y-2 text-right">
                <div class="h-3 w-16 rounded bg-slate-200 animate-pulse ml-auto"></div>
                <div class="h-2 w-20 rounded bg-slate-100 animate-pulse ml-auto"></div>
              </div>
            </div>
            <div class="flex items-center gap-3 p-2">
              <div class="h-7 w-7 rounded-md bg-slate-200 animate-pulse"></div>
              <div class="h-10 w-10 rounded-md bg-slate-200 animate-pulse"></div>
              <div class="flex-1 space-y-2">
                <div class="h-3 w-2/3 rounded bg-slate-200 animate-pulse"></div>
                <div class="h-1.5 w-4/5 rounded-full bg-slate-100 animate-pulse"></div>
              </div>
              <div class="space-y-2 text-right">
                <div class="h-3 w-12 rounded bg-slate-200 animate-pulse ml-auto"></div>
                <div class="h-2 w-16 rounded bg-slate-100 animate-pulse ml-auto"></div>
              </div>
            </div>
          </div>
        </div>
        <div id="top-empty" class="hidden py-8 text-center text-sm text-slate-400">Aucun article en stock</div>
      </div>

      <!-- Status pie -->
      <div class="bg-white rounded-2xl shadow-sm ring-1 ring-slate-200 p-4 md:p-5">
        <h2 class="text-sm font-semibold text-slate-900 mb-3">Statut du stock</h2>
        <div class="relative h-64">
          <canvas id="chart-status"></canvas>
          <div class="chart-loader absolute inset-0 flex flex-col items-center justify-center bg-white/60 backdrop-blur-sm rounded-lg">
            <div class="h-8 w-8 rounded-full border-[3px] border-slate-200 border-t-violet-500 animate-spin mb-2"></div>
            <div class="text-xs text-slate-500 font-medium">Chargement…</div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <!-- Modale détail article (statistiques interactives) -->
  <div id="stat-article-modal" class="hidden fixed inset-0 z-50 items-center justify-center p-4">
    <div id="stat-article-backdrop" class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm"></div>
    <div class="relative w-full max-w-lg bg-white rounded-2xl shadow-2xl ring-1 ring-slate-200 overflow-hidden">
      <button id="stat-modal-close" type="button"
        class="absolute top-3 right-3 inline-flex h-9 w-9 items-center justify-center rounded-lg hover:bg-slate-100 text-slate-400 hover:text-slate-700">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
      <div id="stat-modal-body" class="p-6"></div>
    </div>
  </div>

  <script>
    import '../scripts/stats.js';
  </script>
</Layout>

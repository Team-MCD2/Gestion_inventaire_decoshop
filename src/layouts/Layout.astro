---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import logoImg from "../assets/logo-marchedemo.png";

interface Props {
  title?: string;
  description?: string;
  showNav?: boolean;
}

const BRAND_NAME    = (import.meta.env.PUBLIC_BRAND_NAME    ?? "Marché de Mo'").toString();
const BRAND_TAGLINE = (import.meta.env.PUBLIC_BRAND_TAGLINE ?? "Inventaire intelligent").toString();

const {
  title = `${BRAND_NAME} — ${BRAND_TAGLINE}`,
  description = `Outil d'inventaire ${BRAND_NAME} : caméra, analyse IA et scan code-barres pour les équipes en magasin.`,
  showNav = true,
} = Astro.props;

// Expiration de la session courante (cf. src/middleware.js). Présent uniquement
// quand l'utilisateur est authentifié — on l'utilise pour planifier une
// auto-déconnexion côté client pile à l'expiration.
const authExpiresAt = Astro.locals.authExpiresAt;
---
<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#1C6B35" />
    {authExpiresAt && <meta name="dsh-session-expires-at" content={String(authExpiresAt)} />}
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href={logoImg.src} />

    <!-- Typekit : Filson Pro + Filson Soft (même kit que le site public) -->
    <link rel="preconnect" href="https://use.typekit.net" crossorigin />
    <link rel="preconnect" href="https://p.typekit.net" crossorigin />
    <link rel="stylesheet" href="https://use.typekit.net/tci0qgy.css" />

    <title>{title}</title>
  </head>
  <body class="antialiased bg-white text-slate-900">
    {showNav && <Navbar />}
    <slot />
    <!-- Toast host (shared by every page) -->
    <div id="toast-host" class="fixed top-4 right-4 z-[60] space-y-2 pointer-events-none"></div>

    {authExpiresAt && (
      <script is:inline define:vars={{ expiresAt: authExpiresAt }}>
        // Auto-déconnexion côté client : on planifie un redirect vers /code
        // pile au moment où le cookie de session expire (24h après le
        // login). Utile si l'utilisateur reste sur la même page sans
        // déclencher de requête au serveur.
        (function () {
          const remaining = expiresAt - Date.now();
          const back = encodeURIComponent(location.pathname + location.search);
          const target = '/code?next=' + back;
          if (remaining <= 0) { location.replace(target); return; }
          // setTimeout est plafonné à ~24,8 jours (int32) — sans risque ici (24h).
          setTimeout(() => location.replace(target), remaining + 500);
        })();
      </script>
    )}
  </body>
</html>

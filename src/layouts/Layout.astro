---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";

interface Props {
  title?: string;
  description?: string;
  showNav?: boolean;
}

const {
  title = "DECO SHOP — Inventaire intelligent",
  description = "Inventaire intelligent avec caméra, analyse IA et scan code-barres.",
  showNav = true,
} = Astro.props;
---
<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#1e3a8a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
    <title>{title}</title>
  </head>
  <body class="antialiased bg-slate-50">
    {showNav && <Navbar />}
    <slot />
    <!-- Toast host (shared by every page) -->
    <div id="toast-host" class="fixed top-4 right-4 z-[60] space-y-2 pointer-events-none"></div>
  </body>
</html>
